# Node.js environment variables.
NODE_ENV=
PORT=

# Client Bearer token for authenticating API requests.
CLIENT_BEARER_TOKEN=

# Controller Rust engine connection variables.
CRYPTOGRAPHIC_ENGINE_HOST=
CRYPTOGRAPHIC_ENGINE_PORT=
CRYPTOGRAPHIC_ENGINE_BEARER_TOKEN=

# Redis connection variables.
# In Docker Compose use the service name (redis); locally use 127.0.0.1.
REDIS_HOST=
REDIS_PORT=

# Logging directory for daily log files. Defaults to 'logs'.
LOG_DIRECTORY=
