{
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "excludePrivate": false,
  "excludeProtected": false,
  "excludeInternal": false,
  "readme": "none",
  "disableSources": false,
  "navigation": {
    "includeCategories": true
  },
  "externalSymbolLinkMappings": {
    "@types/node": {
      "\"crypto\".timingSafeEqual": "#"
    },
    "@nestjs/common": {
      "UnauthorizedException": "#"
    },
    "@grpc/grpc-js": {
      "Metadata": "#"
    }
  }
}
