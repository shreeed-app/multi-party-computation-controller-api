{
  "files.eol": "\n",
  "editor.formatOnSave": true,
  "eslint.useFlatConfig": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always"
  },
  "cSpell.words": [
    "appendonly",
    "autonumber",
    "bullmq",
    "catthehacker",
    "cggmp",
    "healthcheck",
    "neverthrow",
    "noexec",
    "nosuid",
    "oneofs",
    "schnorr",
    "secp",
    "solana",
    "tmpfs",
    "treeify"
  ],
  "js/ts.tsdk.path": "node_modules/typescript/lib"
}